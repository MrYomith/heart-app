# Copy this file to .env and fill in the real values. NEVER commit .env.

# Neon PostgreSQL pooled connection string (Europe/Frankfurt region).
# Get it from neon.tech -> your project -> Connect -> pooled connection string.
# Example: postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Falls back to local SQLite for offline dev if DATABASE_URL is empty.
# (UUID/JSONB/ENUM features require PostgreSQL, so use Neon for real work.)

# "development" (default) or "production". In production the app fails to start
# unless SECRET_KEY is set, hides /docs, and sends HSTS.
ENVIRONMENT=development

# Self-hosted login: JWT signing secret (generate with: python -c "import secrets;print(secrets.token_urlsafe(48))").
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated allow-list of front-end origins for CORS (no spaces needed).
# e.g. https://app.mioheart.de,https://dashboard.mioheart.de
CORS_ORIGINS=

# Gunicorn worker count (Docker). Rule of thumb: 2 x CPU cores + 1.
WEB_CONCURRENCY=4

# Claude API key for the Food AI feature (anthropic.com). Optional; feature degrades if unset.
ANTHROPIC_API_KEY=

# Object storage for wound photos / education media. Leave STORAGE_BACKEND=local for
# filesystem (./uploads); set to s3 + the AWS_* vars to use an S3 bucket.
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Firebase Admin service-account JSON path (added when you set up Firebase; not needed for self-hosted login).
# FIREBASE_CREDENTIALS=./secrets/firebase-service-account.json
